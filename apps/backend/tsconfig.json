{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "types": [
            "node",
            "jest"
        ],
        "lib": [
            "ES2022",
            "DOM.Iterable"
        ],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": false,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@shared/*": [
                "../../packages/shared/*"
            ],
            "@src/*": [
                "src/*"
            ]
        },
        "outDir": "./dist",
        "rootDir": ".",
    },
    "include": [
        "src"
    ],
    "references": [
        {
            "path": "../../packages/shared"
        }
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}
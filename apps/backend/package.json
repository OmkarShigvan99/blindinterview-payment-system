{
    "name": "@blindinterview/backend",
    "version": "1.0.0",
    "description": "Backend API for BlindInterview platform",
    "license": "ISC",
    "author": "Omishigvan99",
    "type": "commonjs",
    "main": "dist/index.js",
    "private": true,
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist",
        "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only --require tsconfig-paths/register src/index.ts",
        "build": "pnpm run clean && tsc",
        "start": "cross-env NODE_ENV=production node -r module-alias/register dist/src/index.js"
    },
    "dependencies": {
        "@blindinterview/shared": "workspace:*",
        "@upstash/redis": "^1.35.1",
        "bcrypt": "^6.0.0",
        "cashfree-pg": "^5.0.8",
        "compression": "^1.8.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cross-env": "^7.0.3",
        "currency-codes": "^2.2.0",
        "date-fns": "^4.1.0",
        "dotenv": "^16.5.0",
        "express": "^5.1.0",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "i18n-iso-countries": "^7.14.0",
        "jsonwebtoken": "^9.0.2",
        "mailgen": "^2.0.29",
        "module-alias": "^2.2.3",
        "mongoose": "^8.15.1",
        "nodemailer": "^7.0.3",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "razorpay": "^2.9.6",
        "redis": "^5.6.0",
        "winston": "^3.17.0",
        "zod": "^3.25.62"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^24.0.13",
        "@types/node-fetch": "^2.6.12",
        "@types/nodemailer": "^6.4.17",
        "@types/passport": "^1.0.16",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^8.36.0",
        "@typescript-eslint/parser": "^8.36.0",
        "eslint": "^9.31.0",
        "eslint-config-love": "^121.0.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^17.21.0",
        "eslint-plugin-promise": "^7.2.1",
        "jest": "^30.0.4",
        "mongodb-memory-server": "^10.1.4",
        "prettier": "^3.5.3",
        "supertest": "^7.1.3",
        "ts-jest": "^29.4.0",
        "ts-node-dev": "^2.0.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.8.3"
    },
    "_moduleAliases": {
        "@src": "dist/src",
        "@shared": "../../packages/shared/dist"
    }
}
